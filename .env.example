# =====================================================
# 複製此檔案為 .env 並填入實際值（.env 已在 .gitignore 中）
# =====================================================

# --- 伺服器端專用（不會暴露給前端）---
# Supabase 專案 URL（在 Supabase Dashboard > Settings > API 取得）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key（高權限，只在伺服器端使用，絕不放進前端程式碼）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- 前端可見（PUBLIC_ 前綴，會打包進瀏覽器 JS）---
# 與 SUPABASE_URL 相同值
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon Key（低權限公開金鑰，適合前端 Auth 和即時訂閱）
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
